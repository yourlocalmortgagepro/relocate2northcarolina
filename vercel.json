{
  "version": 2,
  "functions": {
    "api/generate.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/resources",
      "dest": "/resources.html"
    },
    {
      "src": "/relocation-guide",
      "dest": "/relocation-guide.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
